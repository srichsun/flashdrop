#!/bin/bash -e

# If running the rails server then create or migrate existing database.
# Set SKIP_DB_PREPARE=true for a one-off deploy when the database user has no
# permissions yet (App Platform grants them only on a *successful* deploy), then
# unset it and redeploy.
if [ "${@: -2:1}" == "./bin/rails" ] && [ "${@: -1:1}" == "server" ]; then
  if [ "${SKIP_DB_PREPARE}" != "true" ]; then
    ./bin/rails db:prepare
    # Seeds are idempotent, so this just tops the demo data back up after a wipe
    ./bin/rails db:seed
  fi
fi

exec "${@}"
