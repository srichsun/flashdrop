<div class="panel p-8">
  <span class="kicker">Store</span>
  <h1 class="display mt-3 text-3xl font-bold"><%= @tenant.name %></h1>

  <dl class="mt-6 space-y-2 text-sm">
    <div class="flex gap-3">
      <dt class="w-20 muted">Account</dt>
      <dd><%= current_user.email %></dd>
    </div>
    <div class="flex gap-3">
      <dt class="w-20 muted">Role</dt>
      <dd><span class="chip text-xs"><%= current_user.role %></span></dd>
    </div>
  </dl>

  <div class="mt-8 flex flex-wrap gap-3">
    <%= link_to "Manage products", products_path, class: "btn" %>
    <%= link_to "Orders", orders_path, class: "btn btn-ghost" %>
    <%= link_to "View storefront", storefront_store_path(@tenant), class: "btn btn-ghost" %>
  </div>
</div>

<%= turbo_stream_from @tenant %>
<div class="panel mt-6 p-8">
  <h2 class="display text-xl font-bold">Recent sales</h2>
  <div id="orders" class="mt-4">
    <% @orders.each do |order| %><%= render "orders/order", order: order %><% end %>
  </div>
  <p class="muted mt-3 text-xs">New paid orders appear here in real time.</p>
</div>
